# PostgreSQL
POSTGRES_DB=acs_db
POSTGRES_USER=acs_user
POSTGRES_PASSWORD=acs_password
POSTGRES_PORT=5432

# Spring Boot
SPRING_PORT=8080
SPRING_JPA_DDL_AUTO=validate

# Liquibase contexts (comma-separated). Use "dev" to load seed data. Leave empty in production.
LIQUIBASE_CONTEXTS=dev

# JWT — generate with: openssl rand -base64 32
JWT_SECRET=your-base64-encoded-secret-here
# JWT_EXPIRATION=7200000  # optional, default 2h in ms
# JWT_EXPIRATION=172800000  # optional, default 48h in ms